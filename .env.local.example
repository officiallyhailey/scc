# Copy to .env.local and fill in. Never commit .env.local.

# Password to enter the app (single shared password).
APP_PASSWORD=change-me

# Random secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Airtable Personal Access Token (scopes: data.records:read, data.records:write,
# schema.bases:read) — create at https://airtable.com/create/tokens
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reports 2026 base (Silk City Coffee).
AIRTABLE_BASE_ID=app5k6nhYwCIyJ4yH

# Anthropic API key — used server-side to parse uploaded invoices/statements.
# Create at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
